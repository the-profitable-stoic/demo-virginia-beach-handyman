---
/**
 * Recipe: Trust Navy
 * Category: Roofing
 * Reference: Voyager Exteriors style
 * 
 * A complete self-contained homepage recipe.
 * Navy + sage palette, Playfair Display headings, professional trust-focused layout.
 * NO external component imports — everything inline.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import StickyMinimal from "../../components/nav/StickyMinimal.astro";
import MultiColumn from "../../components/footer/MultiColumn.astro";
import { siteConfig } from "../lib/site-config";
import { getSeoForPage } from "../lib/seo";

const seo = getSeoForPage("homepage");
const biz = siteConfig.business;
const content = siteConfig.content;
const homepage = content.homepage;
const services = content.services;
const serviceAreas = content.serviceAreas;
const reviews = content.reviews;
const info = content.companyInfo;
const images = siteConfig.images;
const heroR = (images as any).heroResponsive;
const servicesR = (images as any).servicesResponsive || {};

const displayServices = services.slice(0, 6);
const displayAreas = serviceAreas.slice(0, 8);
const heroServices = services.slice(0, 3);
const displayReviews = reviews.slice(0, 6);
const galleryImages = images.gallery?.length ? images.gallery.slice(0, 6) : Object.values(images.services || {}).slice(0, 3);
const firstFaq = services[0]?.faq || [];

// Slug-to-display-name mapping

const ACRONYMS = new Set(["hvac", "ac", "bbq", "rv", "atv", "suv"]);
function nicheDisplayName(input: string): string {
  return input.split(/[\s-]+/).map(word => {
    if (ACRONYMS.has(word.toLowerCase())) return word.toUpperCase();
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(" ");
}
const categoryDisplay = nicheDisplayName(biz.category);

// Niche-aware language mappings
const medicalNiches = new Set(["dentist", "chiropractor", "physical-therapy", "optometrist", "veterinarian"]);
const autoNiches = new Set(["auto-repair", "auto-body", "auto-detailing", "towing", "tire-shop"]);
const isMedical = medicalNiches.has(biz.category);
const isAuto = autoNiches.has(biz.category);
const ctaText = isMedical ? "Book an Appointment" : "Get a Free Estimate";
const ctaAction = isMedical ? "Schedule a Visit" : isAuto ? "Get a Quote" : "Request an Estimate";

// Niche display name → professional adjective form
const NICHE_ADJECTIVES: Record<string, string> = {
  "dentist": "Dental Care",
  "chiropractor": "Chiropractic Care",
  "optometrist": "Optometry",
  "veterinarian": "Veterinary Care",
  "physical-therapy": "Physical Therapy",
  "auto-repair": "Auto Repair",
  "auto-body": "Auto Body Repair",
  "auto-detailing": "Auto Detailing",
  "towing": "Towing",
  "tire-shop": "Tire Service",
  "electrical": "Electrical Services",
  "solar": "Solar Installation",
  "smart-home": "Smart Home Solutions",
  "handyman": "Handyman Services",
  "general-contractor": "General Contracting",
  "kitchen-remodel": "Kitchen Remodeling",
  "bath-remodel": "Bathroom Remodeling",
  "garage-door": "Garage Door Service",
};
const categoryAdjective = NICHE_ADJECTIVES[biz.category] || categoryDisplay;

// Article helper: "a" vs "an"
const categoryArticle = /^[aeiou]/i.test(categoryDisplay) ? "an" : "a";


---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>

  <!-- ═══════════════════════════════════════════════ NAV ═══════════════════════════════════════════════ -->
  <StickyMinimal slot="nav" />

  <!-- ═══════════════════════════════════════════════ HERO ═══════════════════════════════════════════════ -->
  <section class="tn-hero" style={`background-image: url('${images.hero}')`}>
    <div class="tn-hero__overlay"></div>
    <div class="tn-hero__inner container">
      <div class="tn-hero__content">
        <span class="tn-hero__label">{biz.category.toUpperCase()} EXPERTS</span>
        <h1 class="tn-hero__headline">{homepage.heroHeadline}</h1>
        <p class="tn-hero__subline">{homepage.heroSubline}</p>
        <div class="tn-hero__buttons">
          <a href="/contact" class="btn-primary">{ctaText} &rarr;</a>
          <a href={`tel:${biz.phone}`} class="tn-hero__btn-outline">Call {biz.phone}</a>
        </div>
      </div>

      <div class="tn-hero__form-card">
        <h3 class="tn-hero__form-title">Let's Get Started</h3>
        <form class="tn-hero__form" action="/contact" method="GET">
          <input type="text" name="name" placeholder="Your Name" required class="tn-input" />
          <input type="email" name="email" placeholder="Email Address" required class="tn-input" />
          <input type="tel" name="phone" placeholder="Phone Number" class="tn-input" />
          <select name="service" aria-label="Select a Service" class="tn-input">
            <option value="">Select a Service</option>
            {services.map((s) => (
              <option value={s.slug}>{s.name}</option>
            ))}
          </select>
          <input type="text" name="address" placeholder="Your Address" class="tn-input" />
          <label class="form-consent" style="display:flex;gap:0.5rem;align-items:flex-start;font-size:0.75rem;color:var(--color-text-light,#666);line-height:1.5;margin:0.75rem 0;"><input type="checkbox" name="consent" required style="margin-top:0.2rem;flex-shrink:0" /><span>By submitting, I consent to receive calls/texts from {biz.name} at the number provided. Msg & data rates may apply. Reply STOP to opt out. <a href="/privacy/" style="color:var(--color-primary);text-decoration:underline">Privacy Policy</a> & <a href="/terms/" style="color:var(--color-primary);text-decoration:underline">Terms</a>.</span></label>
            <button type="submit" class="tn-hero__form-submit">GET IN TOUCH &rarr;</button>
        </form>
      </div>
    </div>

    <div class="tn-hero__stats container">
      <div class="tn-hero__stat">
        <span class="tn-hero__stat-num">{info.yearsInBusiness}+</span>
        <span class="tn-hero__stat-label">Years Experience</span>
      </div>
      <div class="tn-hero__stat">
        <span class="tn-hero__stat-num">{info.projectsCompleted}</span>
        <span class="tn-hero__stat-label">{isMedical ? "Patients Served" : "Projects Completed"}</span>
      </div>
      <div class="tn-hero__stat">
        <span class="tn-hero__stat-num">{info.satisfaction}</span>
        <span class="tn-hero__stat-label">Client Satisfaction</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ SERVICES ═══════════════════════════════════════════════ -->
  <section class="tn-services section-padding" id="services">
    <div class="container">
      <p class="tn-section-subtitle">What We Do</p>
      <h2 class="tn-section-heading">Our Services</h2>
      <div class="tn-services__grid">
        {heroServices.map((s) => (
          <a href={`/services/${s.slug}`} class="tn-services__card">
            <img
              src={images.services?.[s.slug] || images.hero}
              alt={s.name}
              class="tn-services__card-img"
              loading="lazy"
            />
            <div class="tn-services__card-overlay">
              <h3 class="tn-services__card-name">{s.name}</h3>
            </div>
          </a>
        ))}
      </div>
      <div class="tn-services__more">
        <a href="/services" class="tn-link-arrow">SEE ALL SERVICES &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ ABOUT / TRUST ═══════════════════════════════════════════════ -->
  <section class="tn-about section-padding" id="about">
    <div class="container">
      <div class="tn-about__grid">
        <div class="tn-about__content">
          <p class="tn-section-subtitle">Who We Are</p>
          <h2 class="tn-section-heading tn-section-heading--left">{homepage.aboutTitle || `Work with A Proven Contractor`}</h2>
          {homepage.aboutText.map((p) => (
            <p class="tn-about__text">{p}</p>
          ))}
          <div class="tn-about__stats">
            <div class="tn-about__stat">
              <span class="tn-about__stat-num">{info.yearsInBusiness}+</span>
              <span class="tn-about__stat-label">Years</span>
            </div>
            <div class="tn-about__stat">
              <span class="tn-about__stat-num">{info.projectsCompleted}</span>
              <span class="tn-about__stat-label">Projects</span>
            </div>
            <div class="tn-about__stat">
              <span class="tn-about__stat-num">{info.satisfaction}</span>
              <span class="tn-about__stat-label">Satisfaction</span>
            </div>
          </div>
          <a href="/contact" class="btn-primary" style="margin-top: 1.5rem;">GET IN TOUCH &rarr;</a>
        </div>
        <div class="tn-about__image-wrap">
          <img src={images.about || images.hero} alt={`${biz.name} team`} class="tn-about__image" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ VALUE PROPS ═══════════════════════════════════════════════ -->
  {homepage.valueProps && homepage.valueProps.length > 0 && (
    <section class="tn-values section-padding">
      <div class="container">
        <p class="tn-section-subtitle">Our Difference</p>
        <h2 class="tn-section-heading">Why Choose {biz.name}</h2>
        <div class="tn-values__grid">
          {homepage.valueProps.map((vp) => (
            <div class="tn-values__card">
              <h3 class="tn-values__card-title">{vp.title}</h3>
              <p class="tn-values__card-desc">{vp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════ CTA ═══════════════════════════════════════════════ -->
  <section class="tn-cta">
    <div class="container tn-cta__inner">
      <h2 class="tn-cta__headline">{homepage.ctaHeadline || `Ready to Get Started?`}</h2>
      <p class="tn-cta__subline">{homepage.ctaSubline || `Contact us today for a free, no-obligation estimate.`}</p>
      <div class="tn-cta__buttons">
        <a href="/contact" class="tn-cta__btn-white">Get a Free Estimate</a>
        <a href={`tel:${biz.phone}`} class="tn-cta__btn-outline">Call {biz.phone}</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ TESTIMONIALS ═══════════════════════════════════════════════ -->
  {displayReviews.length > 0 && (
    <section class="tn-testimonials section-padding" id="reviews">
      <div class="container">
        <p class="tn-section-subtitle">Client Feedback</p>
        <h2 class="tn-section-heading">What Our Clients Say</h2>
        <div class="tn-testimonials__grid">
          {displayReviews.map((r) => (
            <div class="tn-testimonials__card">
              <div class="tn-testimonials__quote-icon">&ldquo;</div>
              <div class="tn-testimonials__stars">
                {Array.from({ length: r.rating }).map(() => (
                  <svg class="tn-testimonials__star" width="16" height="16" viewBox="0 0 24 24" fill="var(--color-accent)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <p class="tn-testimonials__text">{r.text}</p>
              <div class="tn-testimonials__author">
                <span class="tn-testimonials__name">{r.name}</span>
                {r.service && <span class="tn-testimonials__service">{r.service}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════ GALLERY ═══════════════════════════════════════════════ -->
  {galleryImages.length > 0 && (
    <section class="tn-gallery section-padding" id="gallery">
      <div class="container">
        <p class="tn-section-subtitle">Our Portfolio</p>
        <h2 class="tn-section-heading">Our Recent Work</h2>
        <div class="tn-gallery__grid">
          {galleryImages.map((img, i) => (
            <div class="tn-gallery__item">
              <img src={img} alt={`${biz.name} project ${i + 1}`} class="tn-gallery__img" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════ FAQ ═══════════════════════════════════════════════ -->
  {firstFaq.length > 0 && (
    <section class="tn-faq section-padding" id="faq">
      <div class="container">
        <p class="tn-section-subtitle">Common Questions</p>
        <h2 class="tn-section-heading">Frequently Asked Questions</h2>
        <div class="tn-faq__list">
          {firstFaq.map((item) => (
            <details class="tn-faq__item">
              <summary class="tn-faq__question">{item.question}</summary>
              <div class="tn-faq__answer">{item.answer}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════ CONTACT ═══════════════════════════════════════════════ -->
  <section class="tn-contact section-padding" id="contact">
    <div class="container">
      <p class="tn-section-subtitle">Reach Out</p>
      <h2 class="tn-section-heading">Get In Touch</h2>
      <div class="tn-contact__grid">
        <form class="tn-contact__form" action="/contact" method="GET">
          <input type="text" name="name" placeholder="Your Name" required class="tn-input" />
          <input type="email" name="email" placeholder="Email Address" required class="tn-input" />
          <input type="tel" name="phone" placeholder="Phone Number" class="tn-input" />
          <select name="service" aria-label="Select a Service" class="tn-input">
            <option value="">Select a Service</option>
            {services.map((s) => (
              <option value={s.slug}>{s.name}</option>
            ))}
          </select>
          <textarea name="message" placeholder="Tell us about your project..." rows="4" class="tn-input tn-input--textarea"></textarea>
          <label class="form-consent" style="display:flex;gap:0.5rem;align-items:flex-start;font-size:0.75rem;color:var(--color-text-light,#666);line-height:1.5;margin:0.75rem 0;"><input type="checkbox" name="consent" required style="margin-top:0.2rem;flex-shrink:0" /><span>By submitting, I consent to receive calls/texts from {biz.name} at the number provided. Msg & data rates may apply. Reply STOP to opt out. <a href="/privacy/" style="color:var(--color-primary);text-decoration:underline">Privacy Policy</a> & <a href="/terms/" style="color:var(--color-primary);text-decoration:underline">Terms</a>.</span></label>
            <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">Send Message &rarr;</button>
        </form>
        <div class="tn-contact__info">
          <h3 class="tn-contact__info-heading">{biz.name}</h3>
          <p class="tn-contact__info-text">Professional {biz.category.toLowerCase()} services in {biz.city}, {biz.state} and surrounding areas.</p>
          <div class="tn-contact__info-row">
            <strong>Phone</strong>
            <a href={`tel:${biz.phone}`}>{biz.phone}</a>
          </div>
          <div class="tn-contact__info-row">
            <strong>Location</strong>
            <span>{biz.city}, {biz.state}</span>
          </div>
          <div class="tn-contact__info-row">
            <strong>Experience</strong>
            <span>{info.yearsInBusiness}+ Years</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FOOTER ═══════════════════════════════════════════════ -->
  <MultiColumn slot="footer" />

</BaseLayout>

<!-- ═══════════════════════════════════════════════ SCRIPTS ═══════════════════════════════════════════════ -->
<script>
  // Mobile menu toggle
  const btn = document.getElementById("tn-menu-btn");
  const closeBtn = document.getElementById("tn-menu-close");
  const panel = document.getElementById("tn-mobile-panel");
  const overlay = document.getElementById("tn-mobile-overlay");

  function openMenu() {
    panel?.classList.add("is-open");
    overlay?.classList.add("is-open");
    btn?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }
  function closeMenu() {
    panel?.classList.remove("is-open");
    overlay?.classList.remove("is-open");
    btn?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  btn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  overlay?.addEventListener("click", closeMenu);

  // Nav scroll shadow
  const nav = document.getElementById("tn-nav");
  let lastScroll = 0;
  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    if (y > 20) {
      nav?.classList.add("is-scrolled");
    } else {
      nav?.classList.remove("is-scrolled");
    }
    lastScroll = y;
  }, { passive: true });
</script>

<!-- ═══════════════════════════════════════════════ STYLES ═══════════════════════════════════════════════ -->
<style>
  /* ──────────────── NAV ──────────────── */
  .tn-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--color-primary);
    transition: box-shadow 0.3s ease;
  }
  .tn-nav.is-scrolled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
  }
  .tn-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .tn-nav__brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.35rem;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .tn-nav__links {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }
  .tn-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.85rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 4px;
    transition: color 0.2s, background-color 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
  }
  .tn-nav__link:hover {
    color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
  }
  .tn-nav__link svg {
    transition: transform 0.2s;
  }

  /* Dropdown */
  .tn-nav__dropdown {
    position: relative;
  }
  .tn-nav__drop-panel {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background: #fff;
    border-radius: var(--radius-card, 8px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 100;
  }
  .tn-nav__dropdown:hover .tn-nav__drop-panel,
  .tn-nav__dropdown:focus-within .tn-nav__drop-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .tn-nav__dropdown:hover .tn-nav__link svg {
    transform: rotate(180deg);
  }
  .tn-nav__drop-link {
    display: block;
    padding: 0.55rem 1.25rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.88rem;
    transition: background-color 0.15s, color 0.15s;
  }
  .tn-nav__drop-link:hover {
    background-color: var(--color-surface, #f4f6f8);
    color: var(--color-primary);
  }

  /* Nav actions */
  .tn-nav__actions {
    display: none;
    align-items: center;
    gap: 1rem;
  }
  .tn-nav__phone {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .tn-nav__phone:hover { color: #fff; }
  .tn-nav__cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.35rem;
    background: #fff;
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: var(--radius-button, 6px);
    transition: background-color 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .tn-nav__cta-btn:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }

  /* Hamburger */
  .tn-nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .tn-nav__hamburger,
  .tn-nav__hamburger::before,
  .tn-nav__hamburger::after {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s ease;
    position: relative;
  }
  .tn-nav__hamburger::before,
  .tn-nav__hamburger::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
  }
  .tn-nav__hamburger::before { top: -7px; }
  .tn-nav__hamburger::after { top: 7px; }

  /* Mobile panel & overlay */
  .tn-mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1001;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .tn-mobile-overlay.is-open {
    display: block;
    opacity: 1;
  }
  .tn-mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 320px;
    max-width: 85vw;
    background: #fff;
    z-index: 1002;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
  }
  .tn-mobile-panel.is-open {
    transform: translateX(0);
  }
  .tn-mobile-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }
  .tn-mobile-panel__head .tn-nav__brand {
    color: var(--color-primary);
  }
  .tn-mobile-panel__close {
    background: none;
    border: none;
    font-size: 1.75rem;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
    padding: 0.25rem;
  }
  .tn-mobile-panel__body {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 2rem;
  }
  .tn-mobile-panel__link {
    padding: 0.75rem 0;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }
  .tn-mobile-panel__label {
    padding: 0.75rem 0 0.25rem;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .tn-mobile-panel__sublink {
    padding: 0.4rem 0 0.4rem 1rem;
